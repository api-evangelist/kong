{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Certificate",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "cert": {
      "type": "string"
    },
    "key": {
      "type": "string"
    },
    "cert_alt": {
      "type": "string"
    },
    "key_alt": {
      "type": "string"
    },
    "snis": {
      "type": "array"
    },
    "tags": {
      "type": "array"
    },
    "created_at": {
      "type": "integer"
    },
    "updated_at": {
      "type": "integer"
    }
  }
}