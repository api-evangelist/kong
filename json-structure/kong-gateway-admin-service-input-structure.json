{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "ServiceInput",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "protocol": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "port": {
      "type": "integer"
    },
    "path": {
      "type": "string"
    },
    "retries": {
      "type": "integer"
    },
    "connect_timeout": {
      "type": "integer"
    },
    "write_timeout": {
      "type": "integer"
    },
    "read_timeout": {
      "type": "integer"
    },
    "url": {
      "type": "string"
    },
    "tags": {
      "type": "array"
    },
    "client_certificate": {
      "type": "object"
    },
    "tls_verify": {
      "type": "boolean"
    },
    "tls_verify_depth": {
      "type": "integer"
    },
    "ca_certificates": {
      "type": "array"
    },
    "enabled": {
      "type": "boolean"
    }
  }
}