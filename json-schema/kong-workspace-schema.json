{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Workspace",
  "title": "Workspace",
  "x-speakeasy-entity": "Workspace",
  "type": "object",
  "properties": {
    "comment": {
      "description": "A description or additional information about the workspace.",
