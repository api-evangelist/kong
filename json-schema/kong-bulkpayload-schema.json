{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BulkPayload",
  "title": "BulkPayload",
  "description": "Request body schema for bulk status update.",
  "type": "object",
  "properties": {
    "ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 100,
      "minItems": 1,
      "uniqueItems": true
    },
    "status": {
      "$ref": "#/components/schemas/NotificationStatus"
    }
  },
  "required": [
    "ids",
    "status"
  ]
}