{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TimeValue",
  "title": "TimeValue",
  "description": "Represents a time value inclusive of units.",
  "type": "object",
  "properties": {
    "value": {
      "type": "number",
      "example": 3.25
    },
    "unit": {
      "type": "string",
      "example": "hours",
      "enum": [
        "milliseconds",
        "seconds",
        "minutes",
        "hours",
        "days",
        "months",
        "years"
      ],
      "x-speakeasy-unknown-values": "allow"
    }
  },
  "required": [
    "value",
    "unit"
  ]
}