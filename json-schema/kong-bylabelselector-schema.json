{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ByLabelSelector",
  "title": "ByLabelSelector",
  "description": "Entity selector that includes entities by `label` value.",
  "type": "object",
  "properties": {
    "selector": {
      "type": "string",
      "enum": [
        "label"
      ]
    },
    "selector_parameters": {
      "type": "object",
      "properties": {
        "operator": {
          "$ref": "#/components/schemas/StringSelectorOperator"
        },
        "value": {
          "type": "string"
        },
        "label_key": {
          "type": "string"
        }
      },
      "required": [
        "operator",
        "value",
        "label_key"
      ],
      "title": "LabelSelectorParams"
    }
  },
  "required": [
    "selector",
    "selector_parameters"
  ]
}