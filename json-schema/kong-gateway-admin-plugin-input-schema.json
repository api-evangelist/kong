{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PluginInput",
  "type": "object",
  "description": "Input schema for creating or updating a Plugin.",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the plugin."
    },
    "instance_name": {
      "type": "string"
    },
    "config": {
      "type": "object"
    },
    "protocols": {
      "type": "array"
    },
    "enabled": {
      "type": "boolean"
    },
    "tags": {
      "type": "array"
    },
    "ordering": {
      "type": "object"
    },
    "service": {
      "type": "object"
    },
    "route": {
      "type": "object"
    },
    "consumer": {
      "type": "object"
    },
    "consumer_group": {
      "type": "object"
    }
  }
}