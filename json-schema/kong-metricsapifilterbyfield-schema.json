{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MetricsApiFilterByField",
  "title": "Filter by api",
  "oneOf": [
    {
      "title": "Multiselect filters",
      "type": "object",
      "properties": {
        "operator": {
          "$ref": "#/components/schemas/RequestsFilterType"
        },
        "value": {
          "description": "The IDs to include in the results.\n",
          "type": "array",
          "items": {
            "$ref": "#/components/schemas/UnscopedUuid"
          }
        },
        "field": {
          "description": "The field to filter.",
          "type": "string",
          "enum": [
            "api"
          ]
        }
      },
      "required": [
        "operator",
        "value",
        "field"
      ]
    },
    {
      "title": "Empty filters",
      "type": "object",
      "properties": {
        "operator": {
          "$ref": "#/components/schemas/RequestsFilterTypeEmpty"
        },
        "field": {
          "description": "The field to filter.",
          "type": "string",
          "enum": [
            "api"
          ]
        }
      },
      "required": [
        "operator",
        "field"
      ]
    }
  ]
}