{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ResourceKey",
  "title": "Resource Key",
  "description": "A key is a unique string that is used to identify a resource.",
  "type": "string",
  "example": "resource_key",
  "maxLength": 64,
  "minLength": 1,
  "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
}