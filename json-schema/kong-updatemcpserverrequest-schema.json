{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/UpdateMCPServerRequest",
  "title": "UpdateMCPServerRequest",
  "type": "object",
  "properties": {
    "name": {
      "description": "The name of the MCP server.",
      "type": "string",
      "maxLength": 256,
      "minLength": 1
    },
    "description": {
      "description": "A description of the MCP server.",
      "type": "string",
      "maxLength": 1024
    },
    "labels": {
      "description": "Labels for the MCP server.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "control_plane_id": {
      "description": "The control plane ID associated with the MCP server.",
      "type": "string",
      "format": "uuid",
      "nullable": true
    },
    "resource_id": {
      "description": "The MCP resource ID associated with the MCP server.",
      "type": "string",
      "format": "uuid",
      "nullable": true
    }
  },
  "required": [
    "name"
  ]
}