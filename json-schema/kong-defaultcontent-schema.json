{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/DefaultContent",
  "title": "DefaultContent",
  "description": "Summary of created default content",
  "type": "object",
  "properties": {
    "pages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "snippets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
