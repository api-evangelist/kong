{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SchemaRegistryConfluentConfigSensitiveDataAware",
  "title": "SchemaRegistryConfluentConfigSensitiveDataAware",
  "description": "The configuration of [Confluent Schema Registry](https://github.com/confluentinc/schema-registry)\n",
  "type": "object",
  "properties": {
    "schema_type": {
      "description": "The format of the message.",
      "type": "string",
      "enum": [
        "avro",
        "json"
      ],
      "x-speakeasy-unknown-values": "allow"
    },
    "endpoint": {
      "description": "The endpoint of the Confluent schema registry.",
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "timeout_seconds": {
      "description": "Total time in seconds from establishing connection to receive a response from schema registry.\n",
      "type": "integer",
      "default": 10,
      "minimum": 1
    },
    "authentication": {
      "$ref": "#/components/schemas/SchemaRegistryAuthenticationSensitiveDataAwareScheme"
    }
  },
  "required": [
    "schema_type",
    "endpoint"
  ]
}