      "example": true,
      "x-speakeasy-param-computed": true
    },
    "oidc_auth_enabled": {
      "description": "Deprecated. Use the [Identity Provider API](https://developer.konghq.com/api/konnect/portal-management/v3/#/operations/update-portal-identity-provider) instead.",
      "type": "boolean",
      "example": false,
      "deprecated": true,
