{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NodeInfo",
  "type": "object",
  "description": "General details about the Kong Gateway node.",
  "properties": {
    "version": {
      "type": "string",
      "description": "The version of the Kong Gateway instance."
    },
    "lua_version": {
      "type": "string",
      "description": "The version of the Lua runtime."
    },
    "tagline": {
      "type": "string"
    },
    "hostname": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "timers": {
      "type": "object"
    },
    "plugins": {
      "type": "object"
    },
    "configuration": {
      "type": "object"
    }
  }
}