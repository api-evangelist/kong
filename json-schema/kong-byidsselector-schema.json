{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ByIDsSelector",
  "title": "ByIDsSelector",
  "description": "Entity selector that includes entities contained within a list of IDs.",
  "type": "object",
  "properties": {
    "selector": {
      "type": "string",
      "enum": [
        "ids"
      ]
    },
    "selector_parameters": {
      "type": "object",
      "properties": {
        "ids": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "required": [
        "ids"
      ]
    }
  },
  "required": [
    "selector",
    "selector_parameters"
  ]
}