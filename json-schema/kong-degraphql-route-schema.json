{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Degraphql_route",
  "title": "Degraphql_route",
  "type": "object",
  "properties": {
    "created_at": {
      "description": "Unix epoch when the resource was created.",
      "type": "integer",
      "nullable": true
    },
    "id": {
      "description": "A string representing a UUID (universally unique identifier).",
      "type": "string",
      "nullable": true
    },
    "methods": {
      "type": "array",
      "items": {
        "description": "A string representing an HTTP method, such as GET, POST, PUT, or DELETE. The string must contain only uppercase letters.",
        "type": "string"
      },
      "default": [
        "GET"
      ],
      "nullable": true
    },
    "query": {
      "type": "string"
    },
    "service": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        }
      },
      "x-foreign": true
    },
    "updated_at": {
      "description": "Unix epoch when the resource was last updated.",
      "type": "integer",
      "nullable": true
    },
    "uri": {
      "type": "string"
    }
  },
  "example": {
    "id": "56c4566c-14cc-4132-9011-4139fcbbe50a",
    "query": "query{ user { email } }",
    "service": {
      "id": "bd380f99-659d-415e-b0e7-72ea05df3218"
    },
    "uri": "/users"
  },
  "additionalProperties": false,
  "required": [
    "query",
    "uri",
    "service"
  ]
}