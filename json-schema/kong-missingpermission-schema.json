{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/MissingPermission",
  "title": "MissingPermission",
  "type": "object",
  "properties": {
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "nullable": true
      },
      "example": [
        "incident:read"
      ]
    },
    "message": {
      "description": "Describes the degraded experience of the integration instance due to the missing permission.\nMay also include a message on how to resolve the missing permission.\n",
      "type": "string"
    }
  },
  "required": [
    "scopes",
    "message"
  ]
}