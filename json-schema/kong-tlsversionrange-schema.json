{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/TLSVersionRange",
  "title": "TLSVersionRange",
  "description": "A range of TLS versions.",
  "type": "object",
  "properties": {
    "min": {
      "description": "Minimum TLS version to use.",
      "type": "string",
      "default": "TLSv1.2",
      "enum": [
        "TLSv1.2",
        "TLSv1.3"
      ],
      "x-speakeasy-unknown-values": "allow"
    },
    "max": {
      "description": "Maximum TLS version to use.",
      "type": "string",
      "default": "TLSv1.3",
      "enum": [
        "TLSv1.2",
        "TLSv1.3"
      ],
      "x-speakeasy-unknown-values": "allow"
    }
  },
  "default": {
    "min": "TLSv1.2",
    "max": "TLSv1.3"
  }
}