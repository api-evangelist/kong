{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/InvalidParameterDependentItem",
  "title": "InvalidParameterDependentItem",
  "type": "object",
  "properties": {
    "field": {
      "type": "string",
      "example": "name",
      "readOnly": true
    },
    "rule": {
      "description": "invalid parameters rules",
      "type": "string",
      "enum": [
        "dependent_fields"
      ],
      "nullable": true,
      "readOnly": true
    },
    "reason": {
      "type": "string",
      "example": "is a required field",
      "readOnly": true
    },
    "dependents": {
      "type": "array",
      "items": {},
      "nullable": true,
      "readOnly": true,
      "uniqueItems": true
    },
    "source": {
      "type": "string",
      "example": "body"
    }
  },
  "additionalProperties": false,
  "required": [
    "field",
    "rule",
    "reason",
    "dependents"
  ]
}