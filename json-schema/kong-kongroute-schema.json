{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/KongRoute",
  "title": "KongRoute",
  "type": "object",
  "properties": {
    "id": {
      "description": "Route ID",
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "description": "Route name",
      "type": "string",
      "example": "mcp-test-route-jsonrpc"
    },
    "service": {
      "description": "Reference to the service",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "paths": {
      "description": "Request paths",
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "/mcp/test-service"
      ]
    },
    "methods": {
      "description": "HTTP methods",
      "type": "array",
      "items": {
        "type": "string"
      },
      "example": [
        "POST"
      ]
    }
  },
  "required": [
    "name",
    "paths",
    "methods"
  ]
}